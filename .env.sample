# Anthropic API (기본 fallback 모델: Claude Sonnet) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter API (DeepSeek, Qwen, NVIDIA, MiniMax, Kimi 등) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Jamendo API (음악 라이브러리 기능) — https://developer.jamendo.com/v3.0
JAMENDO_CLIENT_ID=your_jamendo_client_id_here
